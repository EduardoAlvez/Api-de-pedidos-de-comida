@startuml
actor Garcom as G
participant ComandaController as CTRL
participant ComandaService as SVC
participant PixService as PIX
participant "MercadoPagoPixClient" as MPCLI
participant ComandaRepository as CREPO
database "H2 Database" as DB
actor "Mercado Pago API" as MPAPI

== Rateio de Itens Compartilhados ==

G -> CTRL: POST /API/V1/comandas/1/rateio\n{\n  "produtoId": 3,\n  "valorPago": 6.00\n}
activate CTRL

CTRL -> SVC: rateio(1L, requestDTO, usuarioLogado)
activate SVC

SVC -> SVC: buscarComanda(1L)
SVC -> SVC: validarComandaAberta()

SVC -> SVC: buscarMesa()  ' obtém mesa da comanda
SVC -> SVC: consultar mesa.itensCompartilhados\n  (busca item com produtoId=3)
SVC -> SVC: validarSaldoRestante()\n  (soma rateios existentes do produto)\n  ' valorPago (6.00) <= saldo restante?

SVC -> SVC: new ComandaRateio(comanda, produto, valorPago)
SVC -> CREPO: save(comanda)
CREPO --> SVC: ok
deactivate SVC

SVC --> CTRL: ComandaRateioResponseDTO
deactivate SVC

CTRL --> G: 200 OK\n{ "id": 1, "produtoId": 3,\n  "valorPago": 6.00 }
deactivate CTRL


== Fechar Conta ==

G -> CTRL: POST /API/V1/comandas/1/fechar\n{ "formaPagamento": "PIX" }
activate CTRL

CTRL -> SVC: fechar(1L, requestDTO, usuarioLogado)
activate SVC

SVC -> SVC: mudar status AGUARDANDO_PIX
SVC -> PIX: gerarQrCode(comanda)
activate PIX

PIX -> PIX: resolverAccessToken()\n  (token do restaurante ou global)
PIX -> MPCLI: criarCobranca(valor,\n                  descricao, accessToken)
activate MPCLI

MPCLI -> MPAPI: POST /v1/orders\n{ "transaction_amount": ...,\n  "description": ...,\n  "payment_method_id": "pix",\n  "payer": { "email": ... } }
activate MPAPI
MPAPI --> MPCLI: 201 Created\n{ "id": "ord_xxx",\n  "qr_code": "...",\n  "qr_code_base64": "..." }
deactivate MPAPI

MPCLI --> PIX: CriarCobrancaResult\n(qrCodeBase64, payloadCopiaCola, txId)
deactivate MPCLI

PIX -> PIX: salvar TransacaoPix\n(comanda, valor, qrCode, status=PENDENTE)
PIX --> SVC: PixResponseDTO\n(qrCodeBase64, payloadCopiaCola)
deactivate PIX

SVC -> CREPO: save(comanda)
CREPO --> SVC: ok

alt última comanda da mesa?
  SVC -> SVC: contarComandasAbertas(mesaId)
  SVC -> SVC: limparItensCompartilhados(mesaId)\n  ' deleta todos ItemCompartilhado da mesa
  SVC -> SVC: alterarStatusMesa(LIVRE)
end

SVC --> CTRL: ComandaResponseDTO\n(status=AGUARDANDO_PIX,\n qrCodeBase64=...,\n payloadCopiaCola=...)
deactivate SVC

CTRL --> G: 200 OK\n{ "status": "AGUARDANDO_PIX",\n  "qrCodeBase64": "iVBOR...", ... }
deactivate CTRL

@enduml
