' https://github.com/hzarsteck/puml-sd-multiline

left to right direction
skinparam packageStyle rectangle

actor Garcom as G
actor "Sistema de Pagamento" as SP

rectangle "Comanda Digital" {
  usecase "Abrir Mesa" as UC1
  usecase "Lançar Item na Comanda" as UC2
  usecase "Editar Item" as UC3
  usecase "Excluir Item" as UC4
  usecase "Fechar Conta" as UC5
  usecase "Cancelar Mesa" as UC6
  usecase "Pagar Presencial" as UC7
  usecase "Pagar PIX" as UC8
  usecase "Rateio" as UC9
  usecase "Adicionar Novo Cliente" as UC10
}

G --> UC1
G --> UC2
G --> UC3
G --> UC4
G --> UC5
G --> UC6
G --> UC10

UC5 <.. UC7 : extends
UC5 <.. UC8 : extends
UC5 <.. UC9 : extends
UC8 --> SP : <<include>>
@enduml
