@startuml
actor Garcom as G
participant ComandaController as CTRL
participant ComandaService as SVC
participant ProdutoRepository as PREPO
participant ComandaRepository as CREPO
database "H2 Database" as DB

G -> CTRL: POST /API/V1/mesas/1/comandas\n{\n  "clienteNome": "Maria",\n  "itens": [\n    { "produtoId": 1, "quantidade": 2 },\n    { "produtoId": 3, "quantidade": 1 }\n  ]\n}
activate CTRL

CTRL -> SVC: criar(1L, requestDTO, usuarioLogado)
activate SVC

SVC -> SVC: validarMesaRestaurante()
SVC -> SVC: validarComandaAberta()

loop para cada item
  SVC -> PREPO: findById(produtoId)
  activate PREPO
  PREPO --> SVC: Produto (com preco)
  deactivate PREPO

  SVC -> SVC: new ComandaItem(produto, quantidade,\n                      precoUnitario)
  SVC -> SVC: calcularValorTotal()
end

SVC -> CREPO: save(comanda)
activate CREPO
CREPO -> DB: INSERT INTO comandas, comanda_itens
DB --> CREPO: ids gerados
CREPO --> SVC: comanda salva
deactivate CREPO

SVC --> CTRL: ComandaResponseDTO\n(com itens + valorTotal)
deactivate SVC

CTRL --> G: 201 Created\n{\n  "id": 3, "status": "ABERTA",\n  "itens": [...],\n  "valorTotal": 83.80\n}
deactivate CTRL

@enduml
